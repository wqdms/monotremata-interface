_monotremata_deployment_script_docker_compose(){\n   curl -H \"ContentType: application/json\" -u \"$MY_USERNAME:$MY_PASS\" \"$DEPLOYMENT_URL/?format=json\"  | jq -r .results[0].script.'docker_compose'\n}\ncmd_podman_build_image(){\n    podman build -f Dockerfile --tag localhost:32000/monotremata-None:latest\n}\n\ncmd_podman_push_image(){\n    podman push localhost:32000/monotremata-None:latest\n}\n\ncmd_podman_update(){\n    cmd_podman_build_image\n    cmd_podman_push_image\n}\n\ncmd_setup_cli_script(){\n    cmd_monotremata_deployment_script_cli > ./cli.sh\n    . ./cli.sh\n}\n\ncmd_cleanup(){\n    rm ./mono.zip\n    rm -drf mono\n}\n\ncmd_git_deployment(){\n    git config --global user.name \"admin:$HOSTNAME\"\n    git config --global user.email \"@groupeffect.de\"\n    git config --global http.sslVerify \"false\"\n    cmd_monotremata_download\n    unzip ./mono.zip -d ./mono\n    git clone http://192.168.179.3:3000/unep/wqdms.git\n    cp -r ./mono/wqdms/. ./wqdms/.\n    git add -A\n    git commit -m \"monotremata deployment | $(date)\"\n    git push \n}\n\n\n", "Dockerfile": "\nFROM docker.io/astral/uv:python3.12-bookworm-slim\nENV PYTHONUNBUFFERED=1 \nENV PYTHONDONTWRITEBYTECODE=1\n\nRUN apt-get update --yes --quiet && apt-get install --yes --quiet --no-install-recommends \\\n\n    git jq yq curl wget nano unzip tk8.6\n\nRUN mkdir -p /app\nCOPY ./ /app\nWORKDIR /app\nRUN uv init\nCMD [\"/bin/bash\",\"-c\",]\n\n", "applicationset": "\napiVersion: argoproj.io/v1alpha1\nkind: Application\nmetadata:\n  name: vo2ovunepwqdms\n  namespace: argocd\nspec:\n  destination:\n    name: ''\n    namespace: unep\n    server: 'https://kubernetes.default.svc'\n  source:\n    path: unep/wqdms/helm\n    repoURL: 'http://10.220.119.12:3000/amir/clustermanager.git' \n    targetRevision: demo\n    helm:\n      valueFiles:\n        - values.yaml\n      parameters:\n        - name: 'environments[0].name'\n          value: 'DB_NAME'\n        - name: 'environments[0].value'\n          value: 'wqdms'\n        - name: 'environments[1].name'\n          value: 'DB_PASSWORD'\n        - name: 'environments[1].value'\n          value: 'sssss'\n        - name: 'environments[2].name'\n          value: 'DB_USER'\n        - name: 'environments[2].value'\n          value: 'wqdms'\n        - name: 'environments[3].name'\n          value: 'DB_HOST'\n        - name: 'environments[3].value'\n          value: 'ge-postgres.database.svc.cluster.local'\n        - name: 'environments[4].name'\n          value: 'DB_PORT'\n        - name: 'environments[4].value'\n          value: '5432'\n        - name: 'ingress.hosts[0].host'\n          value: 'web.groupeffect.app'\n        - name: 'ingress.hosts[1].host'\n          value: 'web.groupeffect.app'\n        - name: image.pullPolicy\n          value: Always\n        - name: image.tag\n          value: 'latest '\n        - name: image.repository\n          value: 'localhost:32000/monotremata'\n        - name: fullnameOverride\n          value: 'vo2ovunepwqdms'\n        - name: SERVICE_URL\n          value: 'http://10.220.119.12:8000'\n        - name: SERVICE_HOST\n          value: '192.168.179.3:8000'\n  sources: []\n  project: default\n  syncPolicy:\n    automated:\n      prune: true\n      selfHeal: false\n    syncOptions:\n      - PruneLast=true\n      - CreateNamespace=true\n      - Replace=true\n\n", "docker_compose": "\n\nx-debugpy: &debugpy\n  build:\n    dockerfile: Dockerfile\n    context: \".\"\n  container_name: wqdms_debugpy\n  environment:\n    DEBUGPY_PORT: 5678\n    DJANGO_PORT: 8000\n    SERVICE_HOST: 192.168.179.3:8000\n    SERVICE_HOST: http://10.220.119.12:8000\n    GIT_HOST:  192.168.179.3:3000\n    GIT_URL:  http://192.168.179.3:3000\n  ports:\n    - 5678:5678 # debugpy\n    - 8000:8000 # backend\n  command: [\"/bin/bash\",\"-c\",\"uv run debugpy --listen 0.0.0.0:5678 manage.py runserver 0.0.0.0:8000\"]\n\nx-jupyter: &jupyter\n  build:\n    dockerfile: Dockerfile\n    context: \".\"\n  container_name: wqdms_